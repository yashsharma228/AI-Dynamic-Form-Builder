# TiDB Cloud connection string (set this on Railway → Variables)
DATABASE_URL=mysql+pymysql://<user>:<password>@<host>:4000/<db>

# OpenAI key (required for AI routes)
OPENAI_API_KEY=sk-...

# Allowed frontend origin(s), comma-separated
CORS_ORIGINS=https://your-app.vercel.app

# Logging level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
