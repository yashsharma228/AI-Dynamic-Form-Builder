# TiDB Cloud connection string (set this on Railway → Variables)
DATABASE_URL=mysql+pymysql://<user>:<password>@<host>:4000/<db>

# OpenRouter AI API key
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_URL=http://localhost:5173
OPENROUTER_APP_NAME=AI Dynamic Form Builder

# Alternative: OpenAI instead of OpenRouter
# OPENAI_API_KEY=sk-...

# Allowed frontend origin(s), comma-separated
CORS_ORIGINS=http://localhost:5173

# Logging level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
